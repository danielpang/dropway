# ─────────────────────────────────────────────────────────────────────────────
# @dropway/dashboard — environment
# Copy to .env.local and fill in. NEVER commit real secrets (.env* is gitignored,
# except this example). The infra agent owns the canonical root .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string Better Auth uses for its identity tables (the
# `identity` schema). Better Auth is the ONLY TS->Postgres path; business data goes
# through the Go API, never a direct DB connection.
DATABASE_URL=postgres://dropway:dropway@localhost:5432/dropway

# Better Auth signing secret (sessions, tokens). Generate a strong random value,
# e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=change-me-please

# Canonical base URL of the dashboard. Locally http://localhost:3000; in cloud
# https://app.dropway.dev. Used for cookie domain + OAuth/magic-link callbacks.
BETTER_AUTH_URL=http://localhost:3000

# Optional: expose the base URL to the browser client (defaults to same-origin).
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth credentials (Google is a core, first-class sign-in method).
# Create at https://console.cloud.google.com/apis/credentials with the redirect
# URI {BETTER_AUTH_URL}/api/auth/callback/google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public base URL of the Go control-plane API (api.dropway.dev). The dashboard
# calls this for ALL business data, carrying a short-lived EdDSA JWT.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Analytics (PostHog) ─────────────────────────────────────────────────────
# All optional: leave unset to disable analytics entirely (self-host friendly).
#
# Deployment label stamped on every analytics event as `environment` (e.g.
# production, staging, self-host). A single literal var used by BOTH the server
# and the browser (exposed to the client via next.config). Defaults to NODE_ENV
# when unset, so it's optional.
# ENVIRONMENT=development
#
# PostHog project API key (phc_...). Safe to expose — it can only ingest events.
# Used by BOTH the browser SDK (pageviews + Web Vitals) and server-side capture
# (signups, sites created, domains added).
# NEXT_PUBLIC_POSTHOG_KEY=
#
# Optional server-only override for the ingest key (defaults to the public key).
# POSTHOG_KEY=
#
# PostHog host. Defaults to US cloud; set to https://eu.posthog.com for the EU.
# NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
#
# Error tracking reuses the keys above — no extra config. The browser SDK
# autocaptures unhandled errors + promise rejections, the React error boundaries
# report through lib/analytics-client.ts (captureClientException), and the server
# captures all uncaught request errors (instrumentation.ts onRequestError) plus
# handled ones via lib/analytics-server.ts (captureServerException), sending them
# to PostHog Error Tracking. Unset keys ⇒ no error reporting. To send errors to a
# different vendor, edit those two seam functions (see docs/components.md →
# "Switching providers"); no other call site touches the SDK.
