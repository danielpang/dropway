# SPDX-License-Identifier: FSL-1.1-Apache-2.0
#
# Dropway — self-host environment template.
# Copy to `deploy/.env` and adjust. NEVER commit a real `.env` (it is gitignored).
#
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml up --build
#
# The values below are SAFE LOCAL DEV DEFAULTS only — rotate every secret before
# exposing anything to a network.

# =============================================================================
# Compose profiles + ports.
# =============================================================================
# Which OPTIONAL bundled data services to start. Default starts the bundled
# Postgres + MinIO + Mailpit so `docker compose up --build` is a one-command full stack.
#   local-db        → bundled Postgres 16
#   local-storage   → bundled MinIO (R2/S3-compatible)
#   local-mail      → bundled Mailpit (SMTP + web inbox at http://localhost:8025)
# To use Supabase (managed Postgres), Cloudflare R2, and/or a real SMTP provider
# instead, REMOVE the matching profile here and point DATABASE_URL /
# DATABASE_OWNER_URL (and/or the S3_* / MAIL_* vars) at your managed service. The
# api/dashboard depend on these with `required: false`, so they run with or
# without the bundled services.
COMPOSE_PROFILES=local-db,local-storage,local-mail

# Host ports the app services publish.
API_PORT=8080          # Go API        → http://localhost:8080
DASHBOARD_PORT=3000    # Next.js app   → http://localhost:3000

# =============================================================================
# Build mode — the open-core switch.
# =============================================================================
# false ⇒ OSS build: the no-op/unlimited QuotaProvider, no Stripe, no caps.
#         Self-host is unlimited; the cloud/ + ee/ modules are NOT present.
# true  ⇒ reserved for the hosted-cloud build ONLY (wires in cloud/quota +
#         cloud/billing via Go build tags / DI). Do not set true for self-host.
DROPWAY_CLOUD=false

# Admin-gating fallback when the Better Auth identity.member table is unavailable.
# false (default, strict) ⇒ admin-gated actions (access/org-policy/role changes)
#         are DENIED when membership/role can't be confirmed live — the JWT role
#         claim is NOT trusted on its own.
# true  ⇒ self-host pre-Better-Auth opt-in: fall back to the verified JWT role
#         claim so the admin gate still functions (logged as a degradation).
ALLOW_JWT_ROLE_FALLBACK=false

# =============================================================================
# Postgres — the single source of truth (app + identity schemas, FORCE RLS).
#
# BUNDLED (default, `local-db` profile) uses the values below. To use SUPABASE or
# another EXTERNAL Postgres: remove `local-db` from COMPOSE_PROFILES and set
# DATABASE_URL + DATABASE_OWNER_URL to your connection strings (e.g. Supabase's
# pooled/session URIs). The runtime role must be NON-superuser / NON-BYPASSRLS;
# on Supabase, apply db/migrations/app as the owner and create a `dropway_app`
# role (the migrations do this when run as the owner).
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dropway
POSTGRES_PORT=5432

# OWNER connection — used ONLY by the goose `migrate` one-shot to apply the app
# schema and provision the runtime role. This is the privileged admin/owner role.
DATABASE_OWNER_URL=postgres://postgres:postgres@postgres:5432/dropway?sslmode=disable

# RUNTIME connection — used by the Go API at request time. Connects as the
# NON-superuser, NON-BYPASSRLS `dropway_app` role (created by migration 0001).
# Every tenant table is FORCE RLS, so this connection is fully subject to the
# per-tenant policies; the Go API does `SET LOCAL app.current_org_id` per tx.
# Must match DROPWAY_APP_DB_PASSWORD below.
DATABASE_URL=postgres://dropway_app:dropway-app-dev-secret@postgres:5432/dropway?sslmode=disable

# BETTER AUTH connection — used by the DASHBOARD's Better Auth, which OWNS + migrates
# the `identity` schema (its own user/session/org/member tables). It must CREATE tables,
# so it needs a PRIVILEGED role — NOT the restricted dropway_app above. Locally we
# reuse the owner; in production use a dedicated role that owns the `identity` schema.
# lib/auth.ts pins this connection's search_path to `identity`. (Falls back to
# DATABASE_URL if unset.)
BETTER_AUTH_DATABASE_URL=postgres://postgres:postgres@postgres:5432/dropway?sslmode=disable

# Password assigned to the `dropway_app` runtime role by the migrate step.
# Keep this in sync with the password embedded in DATABASE_URL above.
DROPWAY_APP_DB_PASSWORD=dropway-app-dev-secret

# =============================================================================
# Object storage — MinIO locally (R2/S3-compatible stand-in for Cloudflare R2).
# Holds per-org blobs/<org_id>/<sha256> and immutable deploy manifests.
# =============================================================================
MINIO_ROOT_USER=dropway
MINIO_ROOT_PASSWORD=dropway-dev-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=dropway-blobs

# S3-style access for the Go API / CLI to reach MinIO. For MinIO these equal the
# root credentials above in dev; use scoped keys in any real deployment.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=dropway
S3_SECRET_ACCESS_KEY=dropway-dev-secret
S3_BUCKET=dropway-blobs
S3_FORCE_PATH_STYLE=true

# BROWSER-reachable object-store host used to SIGN presigned upload URLs (folder
# drag-and-drop deploy from the dashboard PUTs blobs directly to this host). The
# Go API still uses S3_ENDPOINT (http://minio:9000) for its OWN reads/writes — but
# the browser can't resolve the internal 'minio' hostname, so presigned URLs are
# signed against this public host instead. Locally that's the host-published MinIO
# port. If UNSET, presigning falls back to S3_ENDPOINT (correct when the store is
# already a public host, e.g. real Cloudflare R2 — set this to your R2/custom-domain
# host in production, and give that bucket a matching CORS policy).
S3_PUBLIC_ENDPOINT=http://localhost:9000

# CORS origin(s) MinIO allows for those browser blob PUTs. Default '*' (the
# presigned URL is the credential); restrict to your dashboard origin in production.
# MINIO_CORS_ALLOW_ORIGIN=http://localhost:3000

# =============================================================================
# Self-host content server (services/serve) — the Cloudflare-free serving plane.
# =============================================================================
# `serve` serves published tenant sites on *.dropwaycontent.com + custom
# domains (the plain Go alternative to the Cloudflare serving Worker). It reuses
# DATABASE_URL (dropway_app), the S3_* object store, EDGE_JWKS_URL (to VERIFY gated
# edge tokens, fetched server-side from the API), and APP_AUTHZ_URL (the
# BROWSER-facing dashboard /authz it 302s unauthenticated gated requests to).
#
# With CONTENT_DOMAIN=localhost (below), a deploy's live URL is a clickable
#   http://<org>--<app>.localhost:8090/   (*.localhost resolves to 127.0.0.1, no DNS setup).
SERVE_PORT=8090
# Compose defaults point these at the internal api + host-published dashboard;
# override only for an external api / a different dashboard origin.
# SERVE_EDGE_JWKS_URL=http://api:8080/.well-known/edge-jwks
# SERVE_APP_AUTHZ_URL=http://localhost:3000/authz
#
# CONTENT DOMAIN + URL scheme/port — read by the API when it builds a site's host +
# live URL. Sites are served at <org-slug>--<app-slug>.<CONTENT_DOMAIN> (org-namespaced,
# so two orgs can both have an app named "blog" without colliding). We use `localhost`
# locally because *.localhost resolves to 127.0.0.1 in every browser with zero setup.
# Production: CONTENT_DOMAIN=dropwaycontent.com  CONTENT_SCHEME=https  CONTENT_PORT=
# (gated org_only/allowlist/password sites need https for the __Host-edge cookie, so
#  for a quick LOCAL browser view use a PUBLIC site.)
CONTENT_DOMAIN=localhost
CONTENT_SCHEME=http
CONTENT_PORT=8090

# =============================================================================
# MCP server (services/mcp) — LLM-friendly access to gated content.
# =============================================================================
# The Dropway MCP server is an OAuth-protected, remote (Streamable HTTP) Model
# Context Protocol endpoint that lets an AUTHORIZED LLM agent list + read a
# tenant's deployed sites — INCLUDING gated content — scoped to one org by the
# same Postgres RLS (it connects as dropway_app via DATABASE_URL). Public content
# is reachable by crawlers via /llms.txt without MCP; gated content is reachable
# by an LLM ONLY through an authorized MCP connection.
#
# Auth is OAuth 2.1 against the dashboard (Better Auth + @better-auth/oauth-provider):
# the client discovers the authorization server from the MCP server's RFC 9728
# metadata, the user approves in the browser, and the JWT access token is verified
# here against the dashboard JWKS (JWKS_URL above). For the dashboard to issue a JWT
# (not opaque) token, MCP_PUBLIC_URL must be its registered audience — it's used as
# the OAuth `resource`/`aud` AND as the verifier's expected audience, so keep it
# byte-identical across the mcp + dashboard services. `iss` reuses JWT_ISSUER above.
MCP_PORT=8092
# The MCP server's EXTERNAL URL (== OAuth resource/audience). Must be the URL an MCP
# client actually connects to (browser-reachable). Production: https://mcp.dropway.dev
MCP_PUBLIC_URL=http://localhost:8092
# Where the BROWSER's "Connect an AI tool" modal shows the MCP URL. Same value as
# MCP_PUBLIC_URL; NEXT_PUBLIC_ because it's read in a client component.
NEXT_PUBLIC_MCP_URL=http://localhost:8092

# =============================================================================
# Caddy edge (deploy/caddy) — INTERNET-FACING self-host only [profile: edge-tls].
# =============================================================================
# Fronts `serve` with automatic HTTPS, ON-DEMAND TLS for tenant custom domains
# (the open-source Cloudflare-for-SaaS replacement), and response caching that
# honors the serve server's Cache-Control (public cached, gated never cached).
# Real ACME needs public DNS pointed at the box, so this is NOT for localhost —
# enable it by adding `edge-tls` to COMPOSE_PROFILES on an internet-facing host:
#   COMPOSE_PROFILES=local-db,local-storage,local-mail,edge-tls
# CADDY_ACME_EMAIL=you@example.com

# =============================================================================
# Auth — Better Auth issues short-lived EdDSA JWTs; the Go API is the verifier
# and authz boundary. These point the Go verifier at the dashboard's JWKS and
# pin the iss/aud it will accept (the Go verifier rejects alg:none/HS256).
# =============================================================================
# JWKS endpoint published by Better Auth (the dashboard). For self-host this is
# the dashboard container's origin.
JWKS_URL=http://dashboard:3000/api/auth/jwks
# Expected `iss` claim (the dashboard origin that mints tokens).
JWT_ISSUER=http://localhost:3000
# Expected `aud` claim (the Go API origin that consumes tokens).
JWT_AUDIENCE=http://localhost:8080

# =============================================================================
# Dashboard (Next.js + Better Auth) — runs in the `dashboard` container.
# =============================================================================
# Better Auth signing/encryption secret. Generate one with:  openssl rand -hex 32
BETTER_AUTH_SECRET=dev-only-change-me-openssl-rand-hex-32
# The dashboard's own public origin (used by Better Auth for callbacks/cookies).
BETTER_AUTH_URL=http://localhost:3000
# Where the BROWSER reaches the Go API (host-published URL). The dashboard's
# SERVER-side calls (RSC / server actions) use the internal compose hostname instead
# — set by the compose dashboard service to http://api:8080 (DASHBOARD_API_URL),
# because inside the container `localhost` is the container, not the api.
NEXT_PUBLIC_API_URL=http://localhost:8080
# Google OAuth (the first-class sign-in). Optional for local — email/password +
# magic link still work — but Google won't function until these are real.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# --- Email (verification / password reset / magic link) ----------------------
# Dropway sends transactional mail over SMTP — a universal interface, so there's
# NO hard dependency on any one vendor. Point MAIL_SMTP_URL at your own server,
# Gmail, SES, Mailgun, Postmark, Resend's SMTP, or the bundled local Mailpit.
#
#   LOCAL DEFAULT (here): the `local-mail` profile starts Mailpit and we send to it.
#   Every verification / reset / magic-link email lands in Mailpit's web inbox at
#   http://localhost:8025 — click the link there, no real provider needed.
#
#   If MAIL_SMTP_URL is UNSET, email becomes a NO-OP: the message (incl. the link)
#   is LOGGED by the dashboard instead of sent, so a no-email self-host can still
#   complete sign-up / magic-link by copying the link from `docker compose logs
#   dashboard`. Sign-up is never blocked by a missing mail provider.
MAIL_SMTP_URL=smtp://mailpit:1025
# From address on outgoing mail.
MAIL_FROM=Dropway <no-reply@localhost>
# Host port for Mailpit's web inbox (the `local-mail` profile).
MAILPIT_UI_PORT=8025
#
# --- Email verification ------------------------------------------------------
# Require users to verify their email before they can sign in.
#
#   DEFAULT (here): false — friction-free local sign-up (email/password goes
#   straight in; Google is pre-verified). With the bundled Mailpit above you CAN
#   flip this to true locally and click the verification link in the inbox.
#
#   ⚠️  For any INTERNET-FACING deploy you SHOULD set this to true — and point
#   MAIL_SMTP_URL at a REAL SMTP provider (not Mailpit) first, otherwise the
#   verification email never reaches users and they're stuck. The send seam is
#   already wired (apps/dashboard/lib/email.ts + lib/auth.ts); this is just config.
REQUIRE_EMAIL_VERIFICATION=false
#
# NOTE: the dashboard reads BETTER_AUTH_DATABASE_URL (a privileged role that owns the
# `identity` schema) for Better Auth's OWN identity tables. Run Better Auth's migration
# ONCE after first boot (@better-auth/cli is a separate package → pnpm dlx):
#   docker compose -f deploy/docker-compose.yml exec dashboard \
#     pnpm dlx @better-auth/cli@latest migrate --yes

# =============================================================================
# Edge token (Phase 2) — the Go API "edge signer" mints a host-scoped EdDSA JWT
# (SEPARATE keypair from Better Auth's user JWT) that gates password/allowlist/
# org_only sites; the serving Worker verifies it against the JWKS at
# GET /.well-known/edge-jwks. Pin alg=EdDSA; aud = the content host.
# =============================================================================
# Ed25519 signing key: a 32-byte seed or 64-byte private key, base64url/base64/hex.
# Generate a seed with:  openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# If UNSET, the Go API generates an EPHEMERAL key at startup and logs the seed
# (dev only — minted tokens won't survive a restart). MUST be set in production.
# EDGE_SIGNING_KEY=

# =============================================================================
# Edge routing projection — the KV value at route:<host> the serving Worker reads
# (Postgres is authoritative; this projection is rebuildable). The Go API is the
# only writer.
# =============================================================================
# Production writes to Cloudflare Workers KV. Set ALL THREE to enable it.
# CF_ACCOUNT_ID=
# CF_KV_NAMESPACE_ID=
# CF_API_TOKEN=
#
# Self-host / offline: leave the CF_* vars unset and the Go API uses a local
# projection writer. Set PROJECTION_FILE to mirror it to a JSON file the self-host
# serving path can read; unset → purely in-memory (the default in the api
# container — the serving Worker runs separately via `wrangler dev`, not in Compose).
# PROJECTION_FILE=/var/lib/dropway/projection.json

# =============================================================================
# Custom domains (Phase 2) — Cloudflare for SaaS custom hostnames. When CF_ZONE_ID
# is set together with CF_API_TOKEN, the Go API uses the real Cloudflare-for-SaaS
# provider (create custom hostname + poll DCV/TLS status). Unset → an in-memory
# Fake provider (offline/self-host/dev) so the custom-domain endpoints still work.
# =============================================================================
# CF_ZONE_ID=

# =============================================================================
# Cloud-only billing (Stripe) — DO NOT set for self-host.
#
# These are read ONLY by the hosted-cloud build (compiled with the `cloud` Go
# build tag; mountCloud wires cloud/billing from them). The OSS/self-host build
# NEVER reads them and ships WITHOUT cloud/billing — so /webhooks/stripe and
# /v1/billing/* simply don't exist there (self-host is unlimited). They
# live exclusively in the hosted-cloud secret store; documented here for
# completeness. The cloud build only mounts billing when STRIPE_SECRET_KEY +
# STRIPE_WEBHOOK_SECRET are BOTH set (and a DATABASE_URL is present).
# =============================================================================
# Restricted Stripe API key (Checkout + Billing-Portal + Customer creation).
STRIPE_SECRET_KEY=sk_live_xxx
#
# Webhook signing secret — verifies the Stripe-Signature on POST /webhooks/stripe.
# The ONLY thing that may mutate the paid entitlement (plan_tier); a bad/absent
# signature is a hard 400 with no DB write (the browser redirect grants nothing).
STRIPE_WEBHOOK_SECRET=whsec_xxx
#
# Stripe Price ids for the self-serve tiers. They map a Checkout target_tier →
# price AND a webhook subscription's price → plan_tier (so paying raises the cap).
# STRIPE_PRICE_PRO is the $25 tier; STRIPE_PRICE_BUSINESS is the $150 unlimited-sites
# tier (NOTE: STRIPE_PRICE_BUSINESS used to be the $25 price — it is now the $150 price).
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
#
# Dashboard origin used for Checkout success/cancel + Billing-Portal return URLs,
# the quota-modal deep links, and the CLI's `dropway login` OAuth discovery (the
# API's /.well-known/oauth-protected-resource advertises it as the authorization
# server). For local self-host set it to the dashboard you actually run; defaults
# to https://app.dropway.dev when unset.
DASHBOARD_URL=http://localhost:3000
#
# Storage quota enforcement (cloud build only). Default false: per-org storage is
# metered + shown in the dashboard, but a deploy is NEVER rejected for crossing a
# storage band — the only paid lever today is the per-org site count. Flip to true
# once storage billing ships to hold an over-band org until it upgrades. The OSS
# build ignores this (self-host is always unlimited).
ENFORCE_STORAGE_QUOTA=false
