# SPDX-License-Identifier: FSL-1.1-Apache-2.0
#
# Shipped — self-host environment template.
# Copy to `deploy/.env` and adjust. NEVER commit a real `.env` (it is gitignored).
#
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml up --build
#
# The values below are SAFE LOCAL DEV DEFAULTS only — rotate every secret before
# exposing anything to a network.

# =============================================================================
# Compose profiles + ports.
# =============================================================================
# Which OPTIONAL bundled data services to start. Default starts the bundled
# Postgres + MinIO so `docker compose up --build` is a one-command full stack.
#   local-db        → bundled Postgres 16
#   local-storage   → bundled MinIO (R2/S3-compatible)
# To use Supabase (managed Postgres) and/or Cloudflare R2 instead, REMOVE the
# matching profile here and point DATABASE_URL / DATABASE_OWNER_URL (and/or the
# S3_* vars) at your managed service. The api/dashboard depend on these with
# `required: false`, so they run with or without the bundled services.
COMPOSE_PROFILES=local-db,local-storage

# Host ports the app services publish.
API_PORT=8080          # Go API        → http://localhost:8080
DASHBOARD_PORT=3000    # Next.js app   → http://localhost:3000

# =============================================================================
# Build mode — the open-core switch.
# =============================================================================
# false ⇒ OSS build: the no-op/unlimited QuotaProvider, no Stripe, no caps.
#         Self-host is unlimited; the cloud/ + ee/ modules are NOT present.
# true  ⇒ reserved for the hosted-cloud build ONLY (wires in cloud/quota +
#         cloud/billing via Go build tags / DI). Do not set true for self-host.
SHIPPED_CLOUD=false

# Admin-gating fallback when the Better Auth auth.member table is unavailable.
# false (default, strict) ⇒ admin-gated actions (access/org-policy/role changes)
#         are DENIED when membership/role can't be confirmed live — the JWT role
#         claim is NOT trusted on its own.
# true  ⇒ self-host pre-Better-Auth opt-in: fall back to the verified JWT role
#         claim so the admin gate still functions (logged as a degradation).
ALLOW_JWT_ROLE_FALLBACK=false

# =============================================================================
# Postgres — the single source of truth (app + auth schemas, FORCE RLS).
#
# BUNDLED (default, `local-db` profile) uses the values below. To use SUPABASE or
# another EXTERNAL Postgres: remove `local-db` from COMPOSE_PROFILES and set
# DATABASE_URL + DATABASE_OWNER_URL to your connection strings (e.g. Supabase's
# pooled/session URIs). The runtime role must be NON-superuser / NON-BYPASSRLS;
# on Supabase, apply db/migrations/app as the owner and create a `shipped_app`
# role (the migrations do this when run as the owner).
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shipped
POSTGRES_PORT=5432

# OWNER connection — used ONLY by the goose `migrate` one-shot to apply the app
# schema and provision the runtime role. This is the privileged admin/owner role.
DATABASE_OWNER_URL=postgres://postgres:postgres@postgres:5432/shipped?sslmode=disable

# RUNTIME connection — used by the Go API at request time. Connects as the
# NON-superuser, NON-BYPASSRLS `shipped_app` role (created by migration 0001).
# Every tenant table is FORCE RLS, so this connection is fully subject to the
# per-tenant policies; the Go API does `SET LOCAL app.current_org_id` per tx.
# Must match SHIPPED_APP_DB_PASSWORD below.
DATABASE_URL=postgres://shipped_app:shipped-app-dev-secret@postgres:5432/shipped?sslmode=disable

# BETTER AUTH connection — used by the DASHBOARD's Better Auth, which OWNS + migrates
# the `auth` schema (its own user/session/org/member tables). It must CREATE tables,
# so it needs a PRIVILEGED role — NOT the restricted shipped_app above. Locally we
# reuse the owner; in production use a dedicated role that owns the `auth` schema.
# lib/auth.ts pins this connection's search_path to `auth`. (Falls back to
# DATABASE_URL if unset.)
BETTER_AUTH_DATABASE_URL=postgres://postgres:postgres@postgres:5432/shipped?sslmode=disable

# Password assigned to the `shipped_app` runtime role by the migrate step.
# Keep this in sync with the password embedded in DATABASE_URL above.
SHIPPED_APP_DB_PASSWORD=shipped-app-dev-secret

# =============================================================================
# Object storage — MinIO locally (R2/S3-compatible stand-in for Cloudflare R2).
# Holds per-org blobs/<org_id>/<sha256> and immutable deploy manifests.
# =============================================================================
MINIO_ROOT_USER=shipped
MINIO_ROOT_PASSWORD=shipped-dev-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=shipped-blobs

# S3-style access for the Go API / CLI to reach MinIO. For MinIO these equal the
# root credentials above in dev; use scoped keys in any real deployment.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=shipped
S3_SECRET_ACCESS_KEY=shipped-dev-secret
S3_BUCKET=shipped-blobs
S3_FORCE_PATH_STYLE=true

# =============================================================================
# Auth — Better Auth issues short-lived EdDSA JWTs; the Go API is the verifier
# and authz boundary. These point the Go verifier at the dashboard's JWKS and
# pin the iss/aud it will accept (the Go verifier rejects alg:none/HS256).
# =============================================================================
# JWKS endpoint published by Better Auth (the dashboard). For self-host this is
# the dashboard container's origin.
JWKS_URL=http://dashboard:3000/api/auth/jwks
# Expected `iss` claim (the dashboard origin that mints tokens).
JWT_ISSUER=http://localhost:3000
# Expected `aud` claim (the Go API origin that consumes tokens).
JWT_AUDIENCE=http://localhost:8080

# =============================================================================
# Dashboard (Next.js + Better Auth) — runs in the `dashboard` container.
# =============================================================================
# Better Auth signing/encryption secret. Generate one with:  openssl rand -hex 32
BETTER_AUTH_SECRET=dev-only-change-me-openssl-rand-hex-32
# The dashboard's own public origin (used by Better Auth for callbacks/cookies).
BETTER_AUTH_URL=http://localhost:3000
# Where the dashboard reaches the Go API for ALL business data (browser-facing,
# so it must be the host-published URL, not the internal compose hostname).
NEXT_PUBLIC_API_URL=http://localhost:8080
# Google OAuth (the first-class sign-in). Optional for local — email/password +
# magic link still work — but Google won't function until these are real.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# NOTE: the dashboard reads DATABASE_URL (above) for Better Auth's OWN identity
# tables in the `auth` schema. Run Better Auth's migration ONCE after first boot:
#   docker compose -f deploy/docker-compose.yml exec dashboard \
#     pnpm exec @better-auth/cli migrate --yes

# =============================================================================
# Edge token (Phase 2) — the Go API "edge signer" mints a host-scoped EdDSA JWT
# (SEPARATE keypair from Better Auth's user JWT) that gates password/allowlist/
# org_only sites; the serving Worker verifies it against the JWKS at
# GET /.well-known/edge-jwks. Pin alg=EdDSA; aud = the content host.
# =============================================================================
# Ed25519 signing key: a 32-byte seed or 64-byte private key, base64url/base64/hex.
# Generate a seed with:  openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# If UNSET, the Go API generates an EPHEMERAL key at startup and logs the seed
# (dev only — minted tokens won't survive a restart). MUST be set in production.
# EDGE_SIGNING_KEY=

# =============================================================================
# Edge routing projection — the KV value at route:<host> the serving Worker reads
# (Postgres is authoritative; this projection is rebuildable). The Go API is the
# only writer.
# =============================================================================
# Production writes to Cloudflare Workers KV. Set ALL THREE to enable it.
# CF_ACCOUNT_ID=
# CF_KV_NAMESPACE_ID=
# CF_API_TOKEN=
#
# Self-host / offline: leave the CF_* vars unset and the Go API uses a local
# projection writer. Set PROJECTION_FILE to mirror it to a JSON file the self-host
# serving path can read; unset → purely in-memory (the default in the api
# container — the serving Worker runs separately via `wrangler dev`, not in Compose).
# PROJECTION_FILE=/var/lib/shipped/projection.json

# =============================================================================
# Custom domains (Phase 2) — Cloudflare for SaaS custom hostnames. When CF_ZONE_ID
# is set together with CF_API_TOKEN, the Go API uses the real Cloudflare-for-SaaS
# provider (create custom hostname + poll DCV/TLS status). Unset → an in-memory
# Fake provider (offline/self-host/dev) so the custom-domain endpoints still work.
# =============================================================================
# CF_ZONE_ID=

# =============================================================================
# Cloud-only billing (Stripe) — DO NOT set for self-host.
#
# These are read ONLY by the hosted-cloud build (compiled with the `cloud` Go
# build tag; mountCloud wires cloud/billing from them). The OSS/self-host build
# NEVER reads them and ships WITHOUT cloud/billing — so /webhooks/stripe and
# /v1/billing/* simply don't exist there (self-host is unlimited, §9/§14). They
# live exclusively in the hosted-cloud secret store; documented here for
# completeness. The cloud build only mounts billing when STRIPE_SECRET_KEY +
# STRIPE_WEBHOOK_SECRET are BOTH set (and a DATABASE_URL is present).
# =============================================================================
# Restricted Stripe API key (Checkout + Billing-Portal + Customer creation).
# STRIPE_SECRET_KEY=sk_live_xxx
#
# Webhook signing secret — verifies the Stripe-Signature on POST /webhooks/stripe.
# The ONLY thing that may mutate the paid entitlement (plan_tier); a bad/absent
# signature is a hard 400 with no DB write (the browser redirect grants nothing).
# STRIPE_WEBHOOK_SECRET=whsec_xxx
#
# Stripe Price ids for the self-serve tiers. They map a Checkout target_tier →
# price AND a webhook subscription's price → plan_tier (so paying raises the cap).
# STRIPE_PRICE_BUSINESS=price_xxx
# STRIPE_PRICE_ENTERPRISE=price_xxx
#
# Dashboard origin used for Checkout success/cancel + Billing-Portal return URLs
# (and the quota-modal upgrade/contact-sales deep links). Defaults to
# https://app.shipped.app when unset.
# DASHBOARD_URL=https://app.shipped.app
